{
    "version": 10,
    "configurePresets": [
        {
            "name": "macos",
            "displayName": "macos config",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_OSX_SYSROOT": "/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk",
                "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm@21/bin/clang++"
            }
        },
        {
            "name": "macos-debug",
            "displayName": "macos debug",
            "inherits": "macos",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "macos-release",
            "displayName": "macos release",
            "inherits": "macos",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "macos-master",
            "displayName": "macos master",
            "inherits": "macos",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_SHARED_LIBS": "OFF"
            }
        },
        {
            "name": "macos-debug-test",
            "displayName": "macos debug with test and benchmark",
            "inherits": "macos-debug",
            "cacheVariables": {
                "INCLUDE_TEST": "ON",
                "INCLUDE_BENCHMARK": "ON"
            }
        },
        {
            "name": "macos-release-test",
            "displayName": "macos release with test and benchmark",
            "inherits": "macos-release",
            "cacheVariables": {
                "INCLUDE_TEST": "ON",
                "INCLUDE_BENCHMARK": "ON"
            }
        }
    ]
}