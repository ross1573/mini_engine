{
    "version": 10,
    "configurePresets": [
        {
            "name": "windows",
            "displayName": "windows config",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "binaryDir": "${sourceDir}/build"
        },
        {
            "name": "windows-default",
            "displayName": "windows default",
            "inherits": "windows",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON",
                "INCLUDE_TEST": "OFF",
                "INCLUDE_BENCHMARK": "OFF"
            }
        },
        {
            "name": "windows-test",
            "displayName": "windows debug with test and benchmark",
            "inherits": "windows",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON",
                "INCLUDE_TEST": "ON",
                "INCLUDE_BENCHMARK": "ON"
            }
        }
    ]
}