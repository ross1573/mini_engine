{
    "version": 10,
    "configurePresets": [
        {
            "name": "windows",
            "displayName": "windows config",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "binaryDir": "${sourceDir}/build"
        },
        {
            "name": "windows-debug",
            "displayName": "windows debug",
            "inherits": "windows",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "windows-release",
            "displayName": "windows release",
            "inherits": "windows",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "windows-master",
            "displayName": "windows master",
            "inherits": "windows",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_SHARED_LIBS": "OFF"
            }
        },
        {
            "name": "windows-debug-test",
            "displayName": "windows debug with test and benchmark",
            "inherits": "windows-debug",
            "cacheVariables": {
                "INCLUDE_TEST": "ON",
                "INCLUDE_BENCHMARK": "ON"
            }
        },
        {
            "name": "windows-release-test",
            "displayName": "windows release with test and benchmark",
            "inherits": "windows-release",
            "cacheVariables": {
                "INCLUDE_TEST": "ON",
                "INCLUDE_BENCHMARK": "ON"
            }
        }
    ]
}